# ============================================
# Altınbaş Furniture - Environment Variables
# ============================================
# Copy this file as .env and fill in the values:
#   cp .env.example .env
# ============================================

# Environment
NODE_ENV=development
PORT=3000

# Site URL (use the real domain in production)
VITE_SITE_URL=http://localhost:8080

# Admin Login
ADMIN_PASSWORD="admin123"          # min 8 characters
JWT_SECRET=               # min 32 characters, random string

# CORS (comma-separated origins in production)
# CORS_ORIGIN=https://altinbasmobilya.com

# Supabase (Database + Storage)
DATABASE_URL=             # postgresql://user:pass@host:port/db
SUPABASE_URL=             # https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=# Supabase → Settings → API → service_role
SUPABASE_STORAGE_BUCKET=uploads

# Analytics (optional — scripts are not loaded if missing)
# VITE_GTM_ID=GTM-XXXXXXX
# VITE_HOTJAR_ID=1234567

# Sentry Error Tracking (optional — error tracking is disabled if missing)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx   # Frontend
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx         # Backend

# Cloudflare Turnstile (optional — CAPTCHA is disabled if missing)
# VITE_TURNSTILE_SITE_KEY=0x...      # Cloudflare dashboard → Turnstile → Site Key
# TURNSTILE_SECRET_KEY=0x...          # Cloudflare dashboard → Turnstile → Secret Key
